{
  "name": "@sweech/engine",
  "version": "0.1.0",
  "description": "Sweech engine — universal AI agent runner with explicit local-subscription vs API routing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {},
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:regression": "vitest run src/__tests__/regression --reporter=default --reporter=json --outputFile=./coverage/regression-report.json",
    "coverage": "vitest run --coverage",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@anthropic-ai/sdk": "^0.73.0",
    "@hono/node-server": "^1.19.11",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@vykeai/fed": "file:.yalc/@vykeai/fed",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "hono": "^4.12.7",
    "ink": "^7.0.1",
    "js-yaml": "^4.1.1",
    "keytar": "^7.9.0",
    "react": "^19.2.5",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/ink": "^0.5.2",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
